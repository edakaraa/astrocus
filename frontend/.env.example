# =============================================================================
# Astrocus frontend/.env — Expo / React Native
# Kopyala: cp .env.example .env
# EXPO_PUBLIC_* değişince Metro'yu yeniden başlat; release APK/AAB için yeniden build.
# Ayrıntı: prodocs/tech-stack.md#prod-env
# =============================================================================

# --- Ortam ---
# Yerel geliştirme: development | Release / Play build: production
APP_ENV=production
# APP_ENV=development

# --- Supabase (zorunlu) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Express API ---
# Production:
EXPO_PUBLIC_API_URL=https://astrocus.up.railway.app
# Yerel geliştirme (Expo Go + LAN; backend npm run dev port 4000):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:4000
# Ayrıntı: prodocs/tech-stack.md#expo-go-network

# --- Auth deep link (Supabase Redirect URLs ile aynı olmalı) ---
EXPO_PUBLIC_AUTH_VERIFY_REDIRECT_URI=astrocus://verify-success
EXPO_PUBLIC_AUTH_RESET_REDIRECT_URI=astrocus://reset-password

# --- Google OAuth (native Sign-In) ---
# Expo Go'da çalışmaz; release/preview APK gerekir.
# Web client ID → Supabase Google provider + id_token
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=....apps.googleusercontent.com
# Kurulum: prodocs/tech-stack.md#google-oauth

# --- OAuth redirect (opsiyonel) ---
# Yoksa Metro logundaki redirectTo URI'yi Supabase Redirect URLs'e ekle.
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.x.x:8081/--/auth/callback

# --- Ürün analitiği (opsiyonel) ---
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Crash izleme (opsiyonel; production native build) ---
# Expo Go'da native crash yakalanmaz.
# EXPO_PUBLIC_SENTRY_DSN=https://...@....ingest.de.sentry.io/...

# --- Android push (FCM) ---
# Firebase → com.astrocus.app → google-services.json → frontend/ (gitignore)
# Sonra: npx expo prebuild --platform android --clean
# Ayrıntı: prodocs/tech-stack.md#fcm-push

# --- Yerel demo (yalnızca APP_ENV=development + __DEV__) ---
# demo@astrocus.dev / demo1234 — release build'de devre dışı
