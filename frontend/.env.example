# Production (canlı): APP_ENV=production | Yerel geliştirme: APP_ENV=development
APP_ENV=production

# Supabase (zorunlu)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Express API — production
EXPO_PUBLIC_API_URL=https://astrocus.up.railway.app

# Yerel geliştirme: APP_ENV=development ve http://<PC-IP>:4000 — prodocs/tech-stack.md (§10.9)
# EXPO_PUBLIC_API_URL=http://localhost:4000

# OAuth redirect (opsiyonel; yoksa Metro logundaki redirectTo Supabase'e eklenir)
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.1.x:8081/--/auth/callback

# E-posta doğrulama / şifre sıfırlama — Supabase Redirect URLs ile aynı olmalı
EXPO_PUBLIC_AUTH_VERIFY_REDIRECT_URI=astrocus://verify-success
EXPO_PUBLIC_AUTH_RESET_REDIRECT_URI=astrocus://reset-password

# Ürün analitiği — PostHog (Project Settings → Project API key)
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Crash izleme — Sentry React Native DSN (Settings → Projects → Client Keys)
# Production EAS build gerekir; Expo Go'da native crash yakalanmaz.
# EXPO_PUBLIC_SENTRY_DSN=https://...@....ingest.de.sentry.io/...

# Android push (FCM): Firebase'den indir → frontend/google-services.json (gitignore)
# Kurulum: prodocs/tech-stack.md (§10.7 FCM)

# Google Sign-In (native) — EAS secret zorunlu; Expo Go'da çalışmaz
# Web client ID → Supabase Google provider + EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID (id_token için)
# Android client → Google Console SHA-1 + package com.astrocus.app (native SDK)
# Kurulum: prodocs/tech-stack.md (§10.6 Google OAuth)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=....apps.googleusercontent.com

# Production: EXPO_PUBLIC_API_URL zorunlu (app.config.ts). EAS secret: prodocs/tech-stack.md (§10.3)
