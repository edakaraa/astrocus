# Geliştirme: APP_ENV=development | Production EAS build: APP_ENV=production
APP_ENV=development

# Supabase (zorunlu)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Express API (port 4000). LAN: http://<PC-IP>:4000 | Tunnel+API: https://xxxx.ngrok-free.app
# docs/dev-expo-go-networking.md
EXPO_PUBLIC_API_URL=http://localhost:4000

# OAuth redirect (opsiyonel; yoksa Metro logundaki redirectTo Supabase'e eklenir)
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.1.x:8081/--/auth/callback

# E-posta doğrulama / şifre sıfırlama (opsiyonel; yoksa astrocus://… veya exp://…/--/… kullanılır)
# EXPO_PUBLIC_AUTH_VERIFY_REDIRECT_URI=astrocus://verify-success
# EXPO_PUBLIC_AUTH_RESET_REDIRECT_URI=astrocus://reset-password

# Ürün analitiği — PostHog (Project Settings → Project API key)
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Crash izleme — Sentry React Native DSN (Settings → Projects → Client Keys)
# Production EAS build gerekir; Expo Go'da native crash yakalanmaz.
# EXPO_PUBLIC_SENTRY_DSN=https://...@....ingest.de.sentry.io/...

# Production: EXPO_PUBLIC_API_URL zorunlu (app.config.ts). EAS secret örneği: docs/backend-deploy.md
