{
  "expo": {
    "name": "Astrocus",
    "slug": "astrocus",
    "version": "1.0.0",
    "scheme": "astrocus",
    "platforms": [
      "ios",
      "android"
    ],
    "updates": {
      "url": "https://u.expo.dev/936918de-b53c-4d70-8d4c-110698d13797"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/logo.png",
    "splash": {
      "image": "./assets/brand/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1123"
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a"]
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "astrocus"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astrocus.app",
      "usesAppleSignIn": true,
      "icon": "./assets/brand/logo.png"
    },
    "android": {
      "package": "com.astrocus.app",
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/logo.png",
        "backgroundColor": "#0A1123",
        "monochromeImage": "./assets/brand/logo.png"
      },
      "notification": {
        "icon": "./assets/brand/notification-icon.png",
        "color": "#0A1123",
        "androidMode": "default"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "astrocus"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
"extra": {
  "eas": {
    "projectId": "936918de-b53c-4d70-8d4c-110698d13797"
  },
  "googleWebClientId": "",
  "googleAndroidClientId": "",
  "googleIosClientId": ""
}
  }
}
