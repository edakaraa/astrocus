{
  "expo": {
    "name": "Astrocus",
    "slug": "astrocus",
    "version": "1.0.0",
    "scheme": "astrocus",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/logo.png",
    "splash": {
      "image": "./assets/brand/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1123"
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "astrocus"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astrocus.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.astrocus.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/logo.png",
        "backgroundColor": "#0A1123"
      }
    }
  }
}
