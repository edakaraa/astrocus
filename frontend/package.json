{
  "name": "astrocus",
  "version": "1.0.0",
  "private": true,
  "description": "Astrocus mobile MVP",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan -c",
    "start:tunnel": "expo start --tunnel -c",
    "android": "expo run:android",
    "android:local": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-local.ps1",
    "android:release": "powershell -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1",
    "android:bundle": "powershell -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Bundle",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edakaraa/astrocus.git"
  },
  "keywords": [],
  "author": "Eda Kara",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/edakaraa/astrocus/issues"
  },
  "homepage": "https://github.com/edakaraa/astrocus#readme",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
