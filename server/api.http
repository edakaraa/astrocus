@baseUrl = http://localhost:4000
@token = BURAYA_TOKEN_YAPISTIR

### ==================== SYSTEM ====================

### Health check
GET {{baseUrl}}/health

### Bootstrap (oturum acik kullanici verisi)
GET {{baseUrl}}/bootstrap
Authorization: Bearer {{token}}

### ==================== AUTH ====================

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "123456",
  "username": "testuser",
  "galaxyName": "Test Galaksisi"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "123456"
}

### Provider login (Google demo)
POST {{baseUrl}}/auth/provider
Content-Type: application/json

{
  "provider": "google"
}

### ==================== PROFILE ====================

### Profil guncelle
PATCH {{baseUrl}}/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "yeni_isim",
  "language": "en",
  "dailyGoalMinutes": 60
}

### Onboarding tamamla
PATCH {{baseUrl}}/profile
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "onboardingCompleted": true,
  "targetStarId": "solis"
}

### ==================== SESSIONS ====================

### Seans tamamla
POST {{baseUrl}}/sessions/complete
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "categoryId": "coding",
  "durationMinutes": 25,
  "startedAt": "2026-04-27T15:00:00.000Z",
  "completedAt": "2026-04-27T15:25:00.000Z",
  "pauseCount": 0
}

### Offline seans sync
POST {{baseUrl}}/sessions/sync
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "sessions": [
    {
      "id": "offline-session-001",
      "categoryId": "reading",
      "durationMinutes": 30,
      "startedAt": "2026-04-26T10:00:00.000Z",
      "completedAt": "2026-04-26T10:30:00.000Z"
    }
  ]
}
