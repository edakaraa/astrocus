# Supabase (zorunlu — backend/src/lib/supabaseAdmin.ts)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ortam — production deploy'da zorunlu (Sentry vb.)
APP_ENV=production

# HTTP sunucu
PORT=4000
HOST=0.0.0.0
# Production CORS — mobil-only: false | Web istemcisi: https://astrocus.app
ALLOWED_ORIGIN=false

# Haftalık AI rapor (OpenRouter) — backend/.env DEĞİL; Supabase Edge Function secret:
# prodocs/tech-stack.md (§10.8)

# Ürün analitiği (opsiyonel — sunucu tarafı olaylar)
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com

# Crash izleme (opsiyonel — production)
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# Auth e-posta şablonları + SMTP (OTP 15 dk + marka renkleri) — Management API:
# SUPABASE_ACCESS_TOKEN=...  (Dashboard → Account → Access Tokens)
# SUPABASE_PROJECT_REF=yunvuwcaxumhcyqppikn
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_...
# SMTP_ADMIN_EMAIL=onboarding@yourdomain.com
# npm run deploy:auth-email
# Ayrıntı: prodocs/tech-stack.md (§10.5)

