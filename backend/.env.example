# =============================================================================
# Astrocus backend/.env — Express API (Railway / yerel)
# Kopyala: cp .env.example .env
# Ayrıntı: prodocs/tech-stack.md#railway-backend
# =============================================================================

# --- Supabase (zorunlu) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Ortam ---
# Production deploy (Railway): production
APP_ENV=production
# Yerel geliştirme: development veya NODE_ENV boş bırakılabilir
# NODE_ENV=production  # Railway otomatik set edebilir

# --- HTTP sunucu ---
PORT=4000
HOST=0.0.0.0
# Production mobil-only: false | Web istemcisi CORS gerekiyorsa origin URL
ALLOWED_ORIGIN=false

# --- Ürün analitiği (opsiyonel — sunucu tarafı) ---
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com

# --- Crash izleme (opsiyonel — production) ---
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# --- Auth e-posta deploy (npm run deploy:auth-email) ---
# Management API + custom SMTP; OTP 15 dk + HTML şablonlar.
# SUPABASE_ACCESS_TOKEN=sbp_...     # Dashboard → Account → Access Tokens
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_PROJECT_ID=your-project-ref   # alternatif (aynı değer)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_...
# SMTP_ADMIN_EMAIL=onboarding@yourdomain.com
# Ayrıntı: prodocs/tech-stack.md#auth-email-deploy

# --- Supabase Edge secrets (bu dosyaya YAZMAYIN) ---
# OPENROUTER_API_KEY, CRON_SECRET → Dashboard → Edge Functions → Secrets
# Ayrıntı: prodocs/tech-stack.md#haftalik-cron
